# Qwen LLM AMD — Environment Variables
# Copy to .env and fill in values. .env is git-ignored.
#
# Production: copy .env to server and reference in docker-compose or systemd

# ── Model ───────────────────────────────────────────────────
MODEL_PATH=/opt/llm/models/Qwen2.5-14B-Instruct-Q4_K_M.gguf
MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-14B-Instruct-GGUF/resolve/main/Qwen2.5-14B-Instruct-Q4_K_M.gguf

# ── Server ──────────────────────────────────────────────────
LLAMA_HOST=0.0.0.0
LLAMA_PORT=8081
CONTEXT_SIZE=8192
THREADS=6
BATCH_SIZE=512

# ── GPU ─────────────────────────────────────────────────────
GPU_COUNT=2
GPU_LAYERS=99
TENSOR_SPLIT=12,12

# ── ROCm ────────────────────────────────────────────────────
HIP_VISIBLE_DEVICES=0,1
# Must be 10.3.0 for RX 6700 XT (gfx1031)
HSA_OVERRIDE_GFX_VERSION=10.3.0

# ── Tailscale ───────────────────────────────────────────────
# Auth key from https://login.tailscale.com/admin/settings/keys
# NEVER commit this to git
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=udinpc-amd-llm

# ── Hermes AI Integration (consumer) ────────────────────────
# Hermes tier-0 endpoint URL when deployed:
# Hermes tier-0 endpoint: LOCAL_BASE_URL=http://100.106.139.126:8081/v1
